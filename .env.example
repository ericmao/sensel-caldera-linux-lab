# Caldera
CALDERA_REF=5.3.0
CALDERA_API_KEY=ADMIN123

# Training identity
TENANT_ID=castle-train-01
TARGET_AGENT_NAME=caldera-linux-target-01
TARGET_AGENT_NAME_02=caldera-linux-target-02
SANDCAT_GROUP=castle-train-01

# Phase 1: Wazuh agent disabled (enable in Phase 2)
ENABLE_WAZUH=false

# Phase 2: Wazuh Manager connection (existing soc-sensel infrastructure)
WAZUH_MANAGER_HOST=
WAZUH_MANAGER_PORT=1514
WAZUH_ENROLLMENT_HOST=
WAZUH_ENROLLMENT_PORT=1515
WAZUH_AGENT_NAME=caldera-linux-target-01
WAZUH_AGENT_NAME_02=caldera-linux-target-02
WAZUH_ENROLLMENT_MODE=none
# none | key_mount | auto_enroll
WAZUH_AGENT_KEY_PATH=./secrets/client.keys

# Optional: paste deploy command from Caldera UI (Agents -> Deploy -> Linux)
# SANDCAT_DEPLOY_COMMAND=

# Correlation time window (seconds)
CORRELATION_TIME_WINDOW_SEC=300

# Inline NDR gateway (Docker lab) — use: make up-ndr
ENABLE_NDR=false
NDR_PROFILE=it_ndr
NDR_SENSOR_ID=caldera-lab-ndr-01

# NDR cloud stack (inline + Edge Console :8090) — use: make up-ndr-cloud
# Clones vendor/sensel-ot-edge-sensor on first run; copy Portal bundle vars to ndr/portal.env
SENSEL_OT_EDGE_DIR=./vendor/sensel-ot-edge-sensor
SENSEL_OT_EDGE_REF=main
SITE_ID=edge-site-001
SENSOR_ID=caldera-lab-ndr-01
SENSOR_TYPE=it-ndr-edge
SENSEL_API_URL=https://academy.avocadolab.ai
SENSEL_API_KEY=
SENSEL_VERIFY_TLS=true
NORTHBOUND_MQTT_ENABLED=true
CONTROL_PLANE_MQTT_HOST=mqtt.avocadolab.ai
CONTROL_PLANE_MQTT_PORT=1833
MQTT_TENANT_ID=company-a9ae1234648ee138
POLICY_SYNC_TENANT_ID=company-a9ae1234648ee138
OT_REGISTRATION_TOKEN=
SURICATA_SOURCE_ENABLED=true
SURICATA_SOURCE_POLL_SEC=2

# Portal IT NDR Edge (production SPAN) — see ndr/portal.env.example and scripts/setup-ndr-edge.sh
# SENSEL_NDR_BUNDLE_DIR=/path/to/sensel-it-ndr-portal-bundle

# Phase 3: HexStrike MCP + Kali VM (optional, external to Docker lab)
ENABLE_HEXSTRIKE=false
KALI_HOST=192.168.1.110
HEXSTRIKE_SERVER_URL=http://192.168.1.110:8888
HEXSTRIKE_MCP_SCRIPT=/Users/you/hexstrike-ai/hexstrike_mcp.py
HEXSTRIKE_MCP_PYTHON=python3
KALI_SSH_USER=kali
# KALI_SSH_PASSWORD=   # local .env only — for one-time Kali SSH setup, never commit
