# SenseL Portal IT NDR bundle — template for scripts/setup-ndr-edge.sh
# Copy your Portal download .env to ndr/portal.env (gitignored) for production edge deploy.

SITE_ID=edge-site-001
SENSOR_ID=caldera-lab-ndr-01
SENSOR_TYPE=it-ndr-edge
NDR_PROFILE=it_ndr
IDS_RULE_FEED_PROFILE=it_ndr

SENSEL_API_URL=https://academy.avocadolab.ai
SENSEL_API_KEY=
SENSEL_VERIFY_TLS=true

NORTHBOUND_MQTT_ENABLED=true
CONTROL_PLANE_MQTT_HOST=mqtt.avocadolab.ai
CONTROL_PLANE_MQTT_PORT=1833
MQTT_TENANT_ID=company-a9ae1234648ee138
POLICY_SYNC_TENANT_ID=company-a9ae1234648ee138

CAPTURE_INTERFACE=eth0
CAPTURE_BPF_FILTER=
DEPLOY_TARGET=ubuntu

POLICY_SYNC_ENABLED=true
IOC_MATCH_ENABLED=true
SIGHTING_REPORT_ENABLED=true
IDS_RULE_ENABLED=true
IDS_RULE_MQTT_ENABLED=true

OT_REGISTRATION_TOKEN=

DATA_DIR=./data
PCAP_MAX_DISK_MB=1024
PCAP_RETENTION_MINUTES=60
LOG_LEVEL=info

SURICATA_SOURCE_ENABLED=true
SURICATA_INTERFACE=eth0

# Docker lab inline NDR (compose.ndr.yml) — localhost only
NDR_SENSOR_ID=caldera-lab-ndr-01
